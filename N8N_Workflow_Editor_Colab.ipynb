   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 2: 📦 Load Core Engine (n8n_editor_colab.py)\n",
    "\n",
    "Option A: Copy-paste the n8n_editor_colab.py content here\n",
    "Option B: Upload and import"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# If you have n8n_editor_colab.py in your Colab environment:\n",
    "# from n8n_editor_colab import *\n",
    "\n",
    "# Otherwise, let's define the core classes here:\n",
    "\n",
    "from dataclasses import dataclass, field, asdict\n",
    "from typing import Dict, List, Tuple, Optional, Any\n",
    "from enum import Enum\n",
    "import json\n",
    "import uuid\n",
    "from datetime import datetime\n",
    "import networkx as nx\n",
    "\n",
    "print(\"✅ Core imports ready!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 3: 🎯 Create Example Workflow"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Import from the core module\n",
    "from n8n_editor_colab import (\n",
    "    WorkflowDAGEngine, NodeData, EdgeData, NodeType,\n",
    "    WorkflowVisualizer, WorkflowExecutor, WorkflowSerializer,\n",
    "    create_example_workflow\n",
    ")\n",
    "\n",
    "# Create example workflow\n",
    "engine = create_example_workflow()\n",
    "\n",
    "print(\"✅ Example workflow created!\")\n",
    "print(f\"\\n📊 Workflow Stats:\")\n",
    "stats = engine.get_stats()\n",
    "for key, value in stats.items():\n",
    "    if key not in ['created_at', 'updated_at']:\n",
    "        print(f\"   {key}: {value}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 4: 📊 Visualize Workflow"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize the workflow\n",
    "fig = WorkflowVisualizer.visualize(engine)\n",
    "fig.show()\n",
    "\n",
    "print(\"✅ Workflow visualization displayed!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 5: ✅ Validate DAG"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Validate the DAG\n",
    "is_valid, msg = engine.is_valid_dag()\n",
    "print(f\"DAG Validation: {msg}\")\n",
    "\n",
    "# Get execution order\n",
    "order = engine.get_execution_order()\n",
    "print(f\"\\n📋 Execution Order:\")\n",
    "for i, node_id in enumerate(order, 1):\n",
    "    node = engine.get_node(node_id)\n",
    "    print(f\"   {i}. {node.name} ({node.type.value})\")\n",
    "\n",
    "# Detect cycles\n",
    "cycles = engine.detect_cycles()\n",
    "if cycles:\n",
    "    print(f\"\\n⚠️ Cycles detected: {cycles}\")\n",
    "else:\n",
    "    print(f\"\\n✅ No cycles detected!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 6: 🚀 Execute Workflow"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Execute workflow\n",
    "executor = WorkflowExecutor(engine)\n",
    "success, msg = executor.execute({\"sample_data\": \"test\"})\n",
    "\n",
    "print(executor.get_log())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 7: 💾 Export & Import Workflow"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Export workflow as JSON\n",
    "json_str = WorkflowSerializer.to_json(engine, \"My Example Workflow\")\n",
    "print(\"📤 Exported workflow:\")\n",
    "print(json_str[:500] + \"...\\n\")\n",
    "\n",
    "# Save to file\n",
    "with open(\"workflow_example.json\", \"w\") as f:\n",
    "    f.write(json_str)\n",
    "print(\"✅ Saved to workflow_example.json\")\n",
    "\n",
    "# Create new engine and load\n",
    "new_engine = WorkflowDAGEngine()\n",
    "success, msg = WorkflowSerializer.from_json(json_str, new_engine)\n",
    "print(f\"\\n📥 Import result: {msg}\")\n",
    "print(f\"Loaded {len(new_engine.nodes)} nodes and {len(new_engine.edges)} edges\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 8: 🔧 Create Custom Workflow"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create a NEW workflow from scratch\n",
    "custom_engine = WorkflowDAGEngine(\"Email Notification Workflow\")\n",
    "\n",
    "# Add nodes\n",
    "custom_engine.add_node(NodeData(\"start\", \"START\", NodeType.START, (0, 0)))\n",
    "custom_engine.add_node(NodeData(\"check\", \"Check Email\", NodeType.CONDITION, (200, 0), \n",
    "                                 config={\"condition\": \"True\"}))\n",
    "custom_engine.add_node(NodeData(\"send\", \"Send Email\", NodeType.ACTION, (400, 0),\n",
    "                                 config={\"to\": \"user@example.com\", \"subject\": \"Hello\"}))\n",
    "custom_engine.add_node(NodeData(\"end\", \"END\", NodeType.END, (600, 0)))\n",
    "\n",
    "# Add edges\n",
    "custom_engine.add_edge(EdgeData(\"e1\", \"start\", \"check\", \"go\"))\n",
    "custom_engine.add_edge(EdgeData(\"e2\", \"check\", \"send\", \"valid\"))\n",
    "custom_engine.add_edge(EdgeData(\"e3\", \"send\", \"end\", \"done\"))\n",
    "\n",
    "print(\"✅ Custom workflow created!\")\n",
    "print(f\"Nodes: {len(custom_engine.nodes)}, Edges: {len(custom_engine.edges)}\")\n",
    "\n",
    "# Visualize\n",
    "fig = WorkflowVisualizer.visualize(custom_engine)\n",
    "fig.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 9: 📈 Workflow Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Analyze workflow dependencies\n",
    "print(\"🔍 Workflow Analysis:\\n\")\n",
    "\n",
    "for node in engine.list_nodes():\n",
    "    deps = engine.get_node_dependencies(node.id)\n",
    "    dependents = engine.get_node_dependents(node.id)\n",
    "    depth = engine.get_depth(node.id)\n",
    "    \n",
    "    print(f\"📌 {node.name} (ID: {node.id})\")\n",
    "    print(f\"   Type: {node.type.value}\")\n",
    "    print(f\"   Depth: {depth}\")\n",
    "    if deps:\n",
    "        dep_names = [engine.get_node(d).name for d in deps]\n",
    "        print(f\"   Depends on: {', '.join(dep_names)}\")\n",
    "    if dependents:\n",
    "        dep_names = [engine.get_node(d).name for d in dependents]\n",
    "        print(f\"   Affects: {', '.join(dep_names)}\")\n",
    "    print()\n",
    "\n",
    "# Critical path\n",
    "critical_path = engine.get_critical_path()\n",
    "if critical_path:\n",
    "    path_names = [engine.get_node(n).name for n in critical_path]\n",
    "    print(f\"🔴 Critical Path: {' → '.join(path_names)}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 10: 🎨 Interactive Dashboard (Bonus)\n",
    "\n",
    "For a full interactive web UI with Dash, run `colab_dashboard.py` separately:\n",
    "```bash\n",
    "python colab_dashboard.py\n",
    "# Then visit: http://localhost:8050\n",
    "```\n",
    "\n",
    "Or use ipywidgets for inline Colab widgets:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Install ipywidgets\n",
    "!pip install ipywidgets -q\n",
    "\n",
    "import ipywidgets as widgets\n",
    "from IPython.display import display, clear_output, HTML\n",
    "\n",
    "# Create interactive workflow builder\n",
    "node_name_input = widgets.Text(description=\"Node Name:\", value=\"My Node\")\n",
    "node_type_select = widgets.Dropdown(description=\"Type:\", \n",
    "                                     options=[nt.value for nt in NodeType])\n",
    "add_node_button = widgets.Button(description=\"➕ Add Node\", button_style='success')\n",
    "output = widgets.Output()\n",
    "\n",
    "interactive_engine = WorkflowDAGEngine(\"Interactive Workflow\")\n",
    "\n",
    "def on_add_node_clicked(button):\n",
    "    with output:\n",
    "        clear_output()\n",
    "        node_id = f\"n_{len(interactive_engine.nodes)}\"\n",
    "        node = NodeData(node_id, node_name_input.value, \n",
    "                       NodeType(node_type_select.value), (0, 0))\n",
    "        interactive_engine.add_node(node)\n",
    "        print(f\"✅ Added node: {node.name}\")\n",
    "        print(f\"Total nodes: {len(interactive_engine.nodes)}\")\n",
    "\n",
    "add_node_button.on_click(on_add_node_clicked)\n",
    "\n",
    "display(HTML(\"<h3>🎨 Interactive Workflow Builder</h3>\"))\n",
    "display(widgets.VBox([\n",
    "    node_name_input,\n",
    "    node_type_select,\n",
    "    add_node_button,\n",
    "    output\n",
    ]))"
   ]
  },
