# Inicializar engine
engine = WorkflowDAGEngine()

# Criar nós
start = NodeData(id=\"node_1\", name=\"START\", type=NodeType.START, position=(0, 0))
fetch = NodeData(id=\"node_2\", name=\"Fetch Data\", type=NodeType.ACTION, position=(200, 0))
validate = NodeData(id=\"node_3\", name=\"Validate\", type=NodeType.CONDITION, position=(400, 0))
process = NodeData(id=\"node_4\", name=\"Process\", type=NodeType.ACTION, position=(600, 0))
end = NodeData(id=\"node_5\", name=\"END\", type=NodeType.END, position=(800, 0))

# Adicionar nós
engine.add_node(start)
engine.add_node(fetch)
engine.add_node(validate)
engine.add_node(process)
engine.add_node(end)

# Adicionar arestas
engine.add_edge(EdgeData(id=\"e1\", source=\"node_1\", target=\"node_2\", label=\"start\"))
engine.add_edge(EdgeData(id=\"e2\", source=\"node_2\", target=\"node_3\", label=\"success\"))
engine.add_edge(EdgeData(id=\"e3\", source=\"node_3\", target=\"node_4\", label=\"valid\"))
engine.add_edge(EdgeData(id=\"e4\", source=\"node_4\", target=\"node_5\", label=\"done\"))

print(\"✅ Workflow de exemplo criado!\")
print(f\"   - {len(engine.nodes)} nós\")
print(f\"   - {len(engine.edges)} conexões\")


