from ipywidgets import widgets, interactive, HBox, VBox
from IPython.display import display

print(\"\\n🎨 Criando interface interativa...\\n\")

# Widgets
node_name = widgets.Text(description=\"Nome:\", placeholder=\"Ex: My Action\")
node_type = widgets.Dropdown(
    options=[\"start\", \"end\", \"action\", \"condition\", \"loop\", \"webhook\"],
    description=\"Tipo:\",
    value=\"action\"
)
add_btn = widgets.Button(description=\"➕ Adicionar Nó\")
output = widgets.Output()

# Função para adicionar nó
def on_add_node(b):
    with output:
        output.clear_output()
        node_id = f\"node_{len(engine.nodes) + 1}\"
        node = NodeData(
            id=node_id,
            name=node_name.value or \"Untitled\",
            type=NodeType(node_type.value),
            position=(len(engine.nodes) * 150, 0)
        )
        engine.add_node(node)
        print(f\"✅ Nó '{node.name}' adicionado!\")
        print(f\"   Total: {len(engine.nodes)} nós\")

add_btn.on_click(on_add_node)

# Exibir interface
control_panel = VBox([node_name, node_type, add_btn])
display(HBox([control_panel, output]))

print(\"✅ Interface criada! Use os campos acima para adicionar nós.\")


